# Diana runtime
reports/
*.jsonl

# Environment
.env
.env.local

# Claude Code
# Ignore .claude CONTENTS (not the dir itself) so git still descends and the
# re-includes below take effect — a trailing-slash `**/.claude/` blocks descent
# and silently defeats every negation under it.
**/.claude/*
!**/.claude/commands/
!**/.claude/commands/**
!**/.claude/skills/
!**/.claude/skills/**
!**/.claude/agents/
!**/.claude/agents/**

# OS
.DS_Store
Thumbs.db

# Terraform
tf/**/.terraform/
tf/**/.terraform.lock.hcl
tf/**/*.tfstate
tf/**/*.tfstate.backup
tf/**/*.tfplan
tf/**/*.plan
tf/**/terraform.tfvars
tf/**/backend.hcl
tf/**/crash.log
agent-results/
.playwright-mcp/
